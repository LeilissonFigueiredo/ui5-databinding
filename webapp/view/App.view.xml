<mvc:View
    controllerName="ui5.databinding.controller.App"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">

    <Panel 
        headerText="{i18n>panelHeaderText}"
        class="sapUiResponsiveMargin"
        width="auto">

        <form:SimpleForm  editable="true" layout="ResponsiveGridLayout">
            <Label text="{i18n>firstName}"  labelFor="ipFirstName"/>
            <Input id="ipFirsttName" value="{/firstName}" valueLiveUpdate="true" width="200px" editable="{/enabled}"/>
            <Label text="{i18n>lastName}"  labelFor="ipLasttName"/>
            <Input id="ipLasttName" value="{/lastName}" valueLiveUpdate="true" width="200px" editable="{/enabled}"/>   
            <Label text="{i18n>enabled}" labelFor="cbEnabled"/>
            <CheckBox id="cbEnabled" selected="{/enabled}"/>
        </form:SimpleForm>
    </Panel>
    <Panel 
        headerText="{i18n>panel2HeaderText}"
        class="sapUiResponsiveMargin"
        width="auto">
        <content>
            <l:VerticalLayout>
                <Label labelFor="ftAddress" text="{i18n>address}" />
                <FormattedText
                    class="sapUiSmallMarginBottom"
                    htmlText="{/address/street}&lt;br>{/address/zip} {/address/city}&lt;br>{/address/country}"
                    id="ftAddress"
                    width="200px"
                />
                <Link 
                    href="{
                        parts:[
                            '/firstName',
                            '/lastName'
                        ],
                        formatter: '.formatMail'
                    }"
                    text="{i18n>sendEmail}"/>
            </l:VerticalLayout>
        </content>
    </Panel>

</mvc:View>