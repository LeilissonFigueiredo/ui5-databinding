<mvc:View
    controllerName="ui5.databinding.controller.App"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Panel 
        headerText="{i18n>panelHeaderText}"
        class="sapUiResponsiveMargin"
        width="auto">

        <form:SimpleForm  editable="true" layout="ResponsiveGridLayout">
            <Label text="{i18n>firstName}"  labelFor="ipFirstName"/>
            <Input id="ipFirsttName" value="{/firstName}" valueLiveUpdate="true" width="200px" editable="{/enabled}"/>
            <Label text="{i18n>lastName}"  labelFor="ipLasttName"/>
            <Input id="ipLasttName" value="{/lastName}" valueLiveUpdate="true" width="200px" editable="{/enabled}"/>   
            <Label text="{i18n>enabled}" labelFor="cbEnabled"/>
            <CheckBox id="cbEnabled" selected="{/enabled}"/>
        </form:SimpleForm>
    </Panel>
    <Panel 
        headerText="{i18n>panel2HeaderText}"
        class="sapUiResponsiveMargin"
        width="auto">
        <content>
            <l:VerticalLayout>
                <Label labelFor="ftAddress" text="{i18n>address}" />
                <FormattedText
                    class="sapUiSmallMarginBottom"
                    htmlText="{/address/street}&lt;br>{/address/zip} {/address/city}&lt;br>{/address/country}"
                    id="ftAddress"
                    width="200px"
                />
                <Link 
                    href="{
                        parts:[
                            '/firstName',
                            '/lastName'
                        ],
                        formatter: '.formatMail'
                    }"
                    text="{i18n>sendEmail}"/>
            </l:VerticalLayout>
            <l:VerticalLayout >
                <Label text="{i18n>salesAmount}" labelFor="ipSalesAmount"/>
                <Input 
                    core:require="{
                        Currency: 'sap/ui/model/type/Currency'
                    }"
                    enabled="{/enabled}"
                    description="{/currencyCode}"
                    id="ipSalesAmount"
                    value="{
                        parts:[
                            '/salesAmount',
                            '/currencyCode'
                        ],
                        type:'Currency',
                        formatOptions:{
                            showMeasure: false
                        }
                    }"
                    width="200px"/>
            </l:VerticalLayout>
        </content>
    </Panel>
    <Panel 
        headerText="{i18n>panel3HeaderText}"
        class="sapUiResponsiveMargin"
        width="auto">
        <List
            id="liProducts" 
            headerText="{i18n>productListTitle}"
            items="{
                path: 'products>/Products',
                factory: '.productListFactory'
            }">
            <dependents>
             <core:Fragment fragmentName="ui5.databinding.view.ProductSimple" type="XML"/>
             <core:Fragment fragmentName="ui5.databinding.view.ProductExtended" type="XML"/>
            </dependents>
            
        </List>
    </Panel>
    <Panel 
        headerText='{i18n>panel4HeaderText}'
        class='sapUiResponsiveMargin'
        width="auto"
        id="pnProductDetailsPanel">
        <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
            <Label text="{i18n>productID}"  labelFor="ipProductID"/>
            <Input id="ipProductID" value="{products>ProductID}"/>
            
            <Label text="{i18n>productName}"  labelFor="ipProductName"/>
            <Input id="ipProductName" value="{products>ProductName}"/>   

            <Label text="{i18n>quantityPerUnit}" labelFor="ipQuantityPerUnit"/>
			<Input id="ipQuantityPerUnit" value="{products>QuantityPerUnit}"/>

			<Label text="{i18n>unitPrice}" labelFor="ipUnitPrice"/>
			<Input id="ipUnitPrice" value="{products>UnitPrice}"/>

			<Label text="{i18n>unitsInStock}" labelFor="ipUnitInStock"/>
			<Input id="ipUnitInStock" value="{products>UnitsInStock}"/>         

            <Label text="{i18n>discontinued}" labelFor="cbEnabled"/>
            <CheckBox id="cbDiscontinued" selected="{products>Discontinued}"/>
        </form:SimpleForm>
    
    </Panel>

</mvc:View>