<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <ObjectListItem
        id="sliProductExtended"
        core:require="{
            Currency: 'sap/ui/model/type/Currency'
        }" 
        press=".onSelectItem"
        type="Active"
        title="{products>ProductName} ({products>QuantityPerUnit}) "
        number="{
            parts:[
                'products>UnitPrice',
                '/currencyCode'
            ],
            type: 'Currency',
            formatOptions: {
                showMeasure: false
            }      
        }"
        numberUnit="{/currencyCode}"
        numberState="{= ${products>UnitPrice} > ${/priceThreshold} ? 'Error' : 'Success' }">
        <attributes>
            <ObjectAttribute
                title="{i18n>stockValue}" 
                text="{
                    parts:[
                        'products>UnitPrice',
                        'products>UnitsInStock',
                        '/currencyCode'
                    ],
                    formatter:'.formatStockValue' 
                }"/>    
        </attributes>
                
    </ObjectListItem>
         

</core:FragmentDefinition>